# nori-backend test env template — safe to commit, no real secrets.
# Copied into agent users' ~/nori/nori-backend/.env.test by setup_agent_backend_dotenv.
#
# Fields the test infrastructure actually uses (postgres URL, redis URL/host/port,
# FASTAPI_ENV, booleans, plain "test" markers) are kept verbatim. Everything else
# is `<test-placeholder>` — pydantic only requires a string, and tests should mock
# any external service rather than make real calls.

FASTAPI_ENV=testing
DATABASE_URL=postgresql+psycopg://dan:@localhost:5432/nori_test
TEST_DATABASE_URL=postgresql+psycopg://dan:@localhost:5432/nori_test
NORI_INPUT_DATABASE_URL=postgresql+psycopg://dan:@localhost:5432/nori_input_test
INTERNAL_API_KEY=test

TASKIQ_REDIS_URL=redis://localhost:6379
TASKIQ_QUEUES=critical_short_running,default_short_running,webhook
DRAMATIQ_REDIS_URL=redis://localhost:6379
DRAMATIQ_DASHBOARD_PASSWORD=test
ARQ_REDIS_HOST=localhost
ARQ_REDIS_PORT=6379
SHARED_REDIS_HOST=localhost
SHARED_REDIS_PORT=6379

PUBLIC_WEB_ROOT_URL=http://localhost:8000
WEB_ROOT_URL=http://localhost:8000
MARKETING_ROOT_URL=http://localhost:3000
ADMIN_ROOT_URL=http://localhost:3001
MCP_WEB_ROOT_URL=http://localhost:8001
SECONDARY_WEB_ROOT_DOMAIN=.ngrok-free.app
WEB_ROOT_DOMAIN=

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
EPIC_INTEGRATION_ENABLED=True
USE_CADENCE_SCHEDULER=true
APNS_USE_PRODUCTION=false
VERBOSE_DB_LOGGING=false
POSTMARK_INBOUND_WEBHOOK_PASSWORD=test
STRAVA_WEBHOOK_VERIFY_TOKEN=test

IOS_APP_URL_SCHEME=<test-placeholder>
NORI_EMAIL_ADDRESS=<test-placeholder>
TEST_EMAIL=<test-placeholder>
TEST_PHONE_NUMBER=<test-placeholder>
NORI_WHATSAPP_NUMBER=<test-placeholder>

DB_ENCRYPTION_KEY=<test-placeholder>
GOOGLE_API_KEY=<test-placeholder>
OPENAI_API_KEY=<test-placeholder>
LANGSMITH_API_KEY=<test-placeholder>
LANGSMITH_ACCOUNT_ID=<test-placeholder>
LANGSMITH_PROJECT=<test-placeholder>
LANGSMITH_PROJECT_ID=<test-placeholder>

AWS_ACCESS_KEY=<test-placeholder>
